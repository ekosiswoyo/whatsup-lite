{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WhatsUp Lite",
  "version": "0.1.0",
  "identifier": "com.whatsuplite.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "label": "settings",
      "title": "WhatsUp Lite Settings",
      "width": 620,
      "height": 520,
      "resizable": true,
      "visible": false,
      "center": true
    }],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "SocialNetworking",
    "shortDescription": "Lightweight WhatsApp Web desktop client",
    "longDescription": "A lightweight, local-only desktop wrapper for WhatsApp Web.",
    "windows": { "webviewInstallMode": { "type": "downloadBootstrapper", "silent": true } },
    "linux": { "deb": { "depends": [] } }
  }
}
